source "https://rubygems.org"

# Jekyll is the engine that turns your Markdown files into a website.
gem "jekyll", "~> 4.3"

# Plugins
group :jekyll_plugins do
  gem "jekyll-seo-tag", "~> 2.8"   # Nicer titles/links when shared on social media
  gem "jekyll-sitemap", "~> 1.4"   # Helps search engines find your pages
end

# Needed to preview the site on Windows / newer Ruby versions.
gem "webrick", "~> 1.8"
